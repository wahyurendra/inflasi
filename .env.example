# ===========================================
# API Backend
# ===========================================
NEXT_PUBLIC_API_URL="https://api.inflasi.id"

# ===========================================
# ETL Pipeline API Keys
# ===========================================
# EIA (US Energy Information Administration) — harga energi global
# Daftar gratis di: https://www.eia.gov/opendata/register.php
EIA_API_KEY="your-eia-api-key"

# BPS (Badan Pusat Statistik) — data inflasi
# Daftar di: https://webapi.bps.go.id
BPS_API_KEY="your-bps-api-key"

# ===========================================
# Claude API (for AI Assistant)
# ===========================================
ANTHROPIC_API_KEY="sk-ant-xxx"

# ===========================================
# Next.js / NextAuth v5
# ===========================================
NEXT_PUBLIC_APP_URL="https://inflasi.id"

# Wajib di production — generate: openssl rand -base64 32
NEXTAUTH_SECRET="generate-dengan-openssl-rand-base64-32"
