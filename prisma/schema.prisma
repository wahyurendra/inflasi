generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// DIMENSION TABLES
// ============================================================

model DimRegion {
  id            Int      @id @default(autoincrement())
  kodeWilayah   String   @unique @map("kode_wilayah") @db.VarChar(10)
  namaProvinsi  String   @map("nama_provinsi") @db.VarChar(100)
  namaKabKota   String?  @map("nama_kab_kota") @db.VarChar(100)
  levelWilayah  String   @map("level_wilayah") @db.VarChar(20)
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  inflationMonthly  FactInflationMonthly[]
  priceDaily        FactPriceDaily[]
  supplyStock       FactSupplyStock[]
  climate           FactClimate[]
  riskScores        AnalyticsRiskScore[]
  alerts            AnalyticsAlert[]
  forecasts         AnalyticsForecast[]
  anomalies         AnalyticsAnomaly[]
  users             User[]
  priceReports      PriceReport[]

  @@index([levelWilayah], name: "idx_region_level")
  @@index([namaProvinsi], name: "idx_region_provinsi")
  @@map("dim_region")
}

model DimCommodity {
  id             Int      @id @default(autoincrement())
  kodeKomoditas  String   @unique @map("kode_komoditas") @db.VarChar(20)
  namaKomoditas  String   @map("nama_komoditas") @db.VarChar(100)
  namaDisplay    String   @map("nama_display") @db.VarChar(100)
  kategori       String   @db.VarChar(50)
  satuan         String   @db.VarChar(20)
  isStrategis    Boolean  @default(false) @map("is_strategis")
  isMvp          Boolean  @default(true) @map("is_mvp")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  inflationMonthly  FactInflationMonthly[]
  priceDaily        FactPriceDaily[]
  supplyStock       FactSupplyStock[]
  riskScores        AnalyticsRiskScore[]
  alerts            AnalyticsAlert[]
  forecasts         AnalyticsForecast[]
  anomalies         AnalyticsAnomaly[]
  priceReports      PriceReport[]

  @@map("dim_commodity")
}

model DimCalendar {
  tanggal     DateTime @id @db.Date
  tahun       Int
  bulan       Int
  mingguKe    Int      @map("minggu_ke")
  hariKe      Int      @map("hari_ke")
  namaHari    String   @map("nama_hari") @db.VarChar(20)
  isWeekend   Boolean  @default(false) @map("is_weekend")
  isHariLibur Boolean  @default(false) @map("is_hari_libur")
  namaLibur   String?  @map("nama_libur") @db.VarChar(100)
  musim       String?  @db.VarChar(50) // ramadan, idulfitri, nataru, panen_raya, paceklik, normal
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("dim_calendar")
}

// ============================================================
// FACT TABLES
// ============================================================

model FactInflationMonthly {
  id            Int       @id @default(autoincrement())
  periode       DateTime  @db.Date
  regionId      Int       @map("region_id")
  levelWilayah  String    @map("level_wilayah") @db.VarChar(20)
  ihk           Decimal?  @db.Decimal(10, 2)
  inflasiMtm    Decimal?  @map("inflasi_mtm") @db.Decimal(8, 4)
  inflasiYtd    Decimal?  @map("inflasi_ytd") @db.Decimal(8, 4)
  inflasiYoy    Decimal?  @map("inflasi_yoy") @db.Decimal(8, 4)
  kelompok      String?   @db.VarChar(100)
  commodityId   Int?      @map("commodity_id")
  andil         Decimal?  @db.Decimal(8, 4)
  sumber        String    @default("BPS") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relations
  region    DimRegion     @relation(fields: [regionId], references: [id])
  commodity DimCommodity? @relation(fields: [commodityId], references: [id])

  @@unique([periode, regionId, kelompok, commodityId], name: "uq_inflation")
  @@index([periode], name: "idx_inflation_periode")
  @@index([regionId], name: "idx_inflation_region")
  @@index([commodityId], name: "idx_inflation_commodity")
  @@map("fact_inflation_monthly")
}

model FactPriceDaily {
  id                 Int       @id @default(autoincrement())
  tanggal            DateTime  @db.Date
  regionId           Int       @map("region_id")
  commodityId        Int       @map("commodity_id")
  harga              Decimal   @db.Decimal(12, 2)
  hargaKemarin       Decimal?  @map("harga_kemarin") @db.Decimal(12, 2)
  perubahanHarian    Decimal?  @map("perubahan_harian") @db.Decimal(8, 4)
  perubahanMingguan  Decimal?  @map("perubahan_mingguan") @db.Decimal(8, 4)
  perubahanBulanan   Decimal?  @map("perubahan_bulanan") @db.Decimal(8, 4)
  sumber             String    @default("PIHPS_BI") @db.VarChar(50)
  createdAt          DateTime  @default(now()) @map("created_at")

  // Relations
  region    DimRegion    @relation(fields: [regionId], references: [id])
  commodity DimCommodity @relation(fields: [commodityId], references: [id])

  @@unique([tanggal, regionId, commodityId], name: "uq_price_daily")
  @@index([tanggal], name: "idx_price_tanggal")
  @@index([commodityId], name: "idx_price_commodity")
  @@index([regionId], name: "idx_price_region")
  @@index([tanggal, commodityId], name: "idx_price_tanggal_commodity")
  @@map("fact_price_daily")
}

model FactSupplyStock {
  id          Int       @id @default(autoincrement())
  tanggal     DateTime  @db.Date
  regionId    Int       @map("region_id")
  commodityId Int       @map("commodity_id")
  stok        Decimal?  @db.Decimal(15, 2)
  cadangan    Decimal?  @db.Decimal(15, 2)
  status      String?   @db.VarChar(20) // aman, waspada, kritis
  sumber      String    @default("BAPANAS") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  region    DimRegion    @relation(fields: [regionId], references: [id])
  commodity DimCommodity @relation(fields: [commodityId], references: [id])

  @@unique([tanggal, regionId, commodityId], name: "uq_supply_stock")
  @@map("fact_supply_stock")
}

model FactMacroDriver {
  id            Int       @id @default(autoincrement())
  tanggal       DateTime  @unique @db.Date
  kursUsdIdr    Decimal?  @map("kurs_usd_idr") @db.Decimal(12, 2)
  kursChangePct Decimal?  @map("kurs_change_pct") @db.Decimal(8, 4)
  hargaBbm      Decimal?  @map("harga_bbm") @db.Decimal(10, 2)
  sumberKurs    String    @default("BI_JISDOR") @map("sumber_kurs") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([tanggal], name: "idx_macro_tanggal")
  @@map("fact_macro_driver")
}

model FactClimate {
  id           Int       @id @default(autoincrement())
  tanggal      DateTime  @db.Date
  regionId     Int       @map("region_id")
  curahHujan   Decimal?  @map("curah_hujan") @db.Decimal(8, 2)
  suhuRata     Decimal?  @map("suhu_rata") @db.Decimal(5, 2)
  anomaliCuaca String?   @map("anomali_cuaca") @db.VarChar(100)
  warningLevel String?   @map("warning_level") @db.VarChar(20)
  sumber       String    @default("BMKG") @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  region DimRegion @relation(fields: [regionId], references: [id])

  @@unique([tanggal, regionId], name: "uq_climate")
  @@index([tanggal], name: "idx_climate_tanggal")
  @@index([regionId], name: "idx_climate_region")
  @@map("fact_climate")
}

// ============================================================
// ANALYTICS TABLES (Derived)
// ============================================================

model AnalyticsRiskScore {
  id                  Int       @id @default(autoincrement())
  tanggal             DateTime  @db.Date
  regionId            Int       @map("region_id")
  commodityId         Int       @map("commodity_id")
  skorKenaikan7d      Decimal?  @map("skor_kenaikan_7d") @db.Decimal(5, 2)
  skorKenaikan30d     Decimal?  @map("skor_kenaikan_30d") @db.Decimal(5, 2)
  skorVolatilitas     Decimal?  @map("skor_volatilitas") @db.Decimal(5, 2)
  skorDeviasiWilayah  Decimal?  @map("skor_deviasi_wilayah") @db.Decimal(5, 2)
  skorCuaca           Decimal?  @map("skor_cuaca") @db.Decimal(5, 2)
  skorStok            Decimal?  @map("skor_stok") @db.Decimal(5, 2)
  riskScoreTotal      Decimal?  @map("risk_score_total") @db.Decimal(5, 2)
  riskCategory        String?   @map("risk_category") @db.VarChar(20)
  createdAt           DateTime  @default(now()) @map("created_at")

  // Relations
  region    DimRegion    @relation(fields: [regionId], references: [id])
  commodity DimCommodity @relation(fields: [commodityId], references: [id])

  @@unique([tanggal, regionId, commodityId], name: "uq_risk_score")
  @@map("analytics_risk_score")
}

model AnalyticsAlert {
  id             Int       @id @default(autoincrement())
  tanggal        DateTime  @db.Date
  regionId       Int       @map("region_id")
  commodityId    Int       @map("commodity_id")
  alertType      String    @map("alert_type") @db.VarChar(50)
  severity       String    @db.VarChar(20)
  judul          String    @db.VarChar(200)
  deskripsi      String    @db.Text
  nilaiAktual    Decimal?  @map("nilai_aktual") @db.Decimal(12, 2)
  nilaiThreshold Decimal?  @map("nilai_threshold") @db.Decimal(12, 2)
  isActive       Boolean   @default(true) @map("is_active")
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  region    DimRegion    @relation(fields: [regionId], references: [id])
  commodity DimCommodity @relation(fields: [commodityId], references: [id])

  @@index([isActive, tanggal], name: "idx_alerts_active")
  @@index([severity], name: "idx_alerts_severity")
  @@map("analytics_alerts")
}

model AnalyticsInsight {
  id           Int       @id @default(autoincrement())
  tanggal      DateTime  @db.Date
  tipe         String    @db.VarChar(20)
  judul        String    @db.VarChar(200)
  konten       String    @db.Text
  dataSnapshot Json?     @map("data_snapshot")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("analytics_insights")
}

// ============================================================
// EXTERNAL DATASETS — Global Market & Intelligence
// ============================================================

// Tier 4: FAO Food Price Index (monthly)
model ExtFaoFoodPrice {
  id            Int       @id @default(autoincrement())
  periode       DateTime  @db.Date
  indexOverall  Decimal?  @map("index_overall") @db.Decimal(8, 2)
  indexCereals  Decimal?  @map("index_cereals") @db.Decimal(8, 2)
  indexVegOil   Decimal?  @map("index_veg_oil") @db.Decimal(8, 2)
  indexDairy    Decimal?  @map("index_dairy") @db.Decimal(8, 2)
  indexMeat     Decimal?  @map("index_meat") @db.Decimal(8, 2)
  indexSugar    Decimal?  @map("index_sugar") @db.Decimal(8, 2)
  changePct     Decimal?  @map("change_pct") @db.Decimal(8, 4)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@unique([periode], name: "uq_fao_periode")
  @@map("ext_fao_food_price")
}

// Tier 4: World Bank & Global Commodity Prices (monthly)
model ExtCommodityPrice {
  id          Int       @id @default(autoincrement())
  periode     DateTime  @db.Date
  commodity   String    @db.VarChar(50)    // rice, wheat, corn, palm_oil, sugar, soybean, urea, crude_oil
  price       Decimal   @db.Decimal(12, 2) // USD per metric ton (or barrel for oil)
  unit        String    @db.VarChar(30)
  changePct   Decimal?  @map("change_pct") @db.Decimal(8, 4)
  sumber      String    @default("WORLD_BANK") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([periode, commodity], name: "uq_commodity_price")
  @@index([commodity], name: "idx_ext_commodity")
  @@map("ext_commodity_price")
}

// Tier 4: Exchange Rate USD/IDR (daily)
model ExtExchangeRate {
  id          Int       @id @default(autoincrement())
  tanggal     DateTime  @unique @db.Date
  kursJual    Decimal?  @map("kurs_jual") @db.Decimal(12, 2)
  kursBeli    Decimal?  @map("kurs_beli") @db.Decimal(12, 2)
  kursTengah  Decimal?  @map("kurs_tengah") @db.Decimal(12, 2)
  changePct   Decimal?  @map("change_pct") @db.Decimal(8, 4)
  sumber      String    @default("ECB") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tanggal], name: "idx_ext_kurs_tanggal")
  @@map("ext_exchange_rate")
}

// Tier 4: Energy Prices — Brent, WTI, LNG (daily)
model ExtEnergyPrice {
  id          Int       @id @default(autoincrement())
  tanggal     DateTime  @db.Date
  commodity   String    @db.VarChar(30)    // brent, wti, lng, natural_gas
  price       Decimal   @db.Decimal(10, 2) // USD per barrel / MMBtu
  changePct   Decimal?  @map("change_pct") @db.Decimal(8, 4)
  sumber      String    @default("EIA") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([tanggal, commodity], name: "uq_energy_price")
  @@index([tanggal], name: "idx_ext_energy_tanggal")
  @@map("ext_energy_price")
}

// Tier 5: Global Supply Chain Pressure Index (monthly, Fed NY)
model ExtSupplyChainIndex {
  id          Int       @id @default(autoincrement())
  periode     DateTime  @unique @db.Date
  gscpi       Decimal   @db.Decimal(8, 4)  // index value (std dev from mean)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("ext_supply_chain_index")
}

// Tier 6-7: News Intelligence Signals
model ExtNewsSignal {
  id          Int       @id @default(autoincrement())
  tanggal     DateTime  @db.Date
  kategori    String    @db.VarChar(50)    // food_supply, energy, geopolitics, climate, agriculture
  judul       String    @db.VarChar(500)
  sumber      String    @db.VarChar(100)   // GDELT, manual
  url         String?   @db.VarChar(500)
  sentimen    String?   @db.VarChar(20)    // negative, neutral, positive
  relevansi   Decimal?  @db.Decimal(5, 2)  // 0-100 relevance score
  ringkasan   String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tanggal, kategori], name: "idx_news_tanggal_kategori")
  @@map("ext_news_signal")
}

// ============================================================
// AI/ML OUTPUT TABLES
// ============================================================

// Price Forecast (Prophet H+7/H+14)
model AnalyticsForecast {
  id            Int       @id @default(autoincrement())
  tanggal       DateTime  @db.Date
  regionId      Int       @map("region_id")
  commodityId   Int       @map("commodity_id")
  horizon       Int       // 7 or 14 days
  yhat          Decimal   @db.Decimal(12, 2)
  yhatLower     Decimal   @map("yhat_lower") @db.Decimal(12, 2)
  yhatUpper     Decimal   @map("yhat_upper") @db.Decimal(12, 2)
  modelVersion  String    @map("model_version") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at")

  region    DimRegion    @relation(fields: [regionId], references: [id])
  commodity DimCommodity @relation(fields: [commodityId], references: [id])

  @@unique([tanggal, regionId, commodityId, horizon], name: "uq_forecast")
  @@index([tanggal, commodityId], name: "idx_forecast_tanggal_commodity")
  @@map("analytics_forecast")
}

// Anomaly Detection (Isolation Forest)
model AnalyticsAnomaly {
  id            Int       @id @default(autoincrement())
  tanggal       DateTime  @db.Date
  regionId      Int       @map("region_id")
  commodityId   Int       @map("commodity_id")
  anomalyScore  Decimal   @map("anomaly_score") @db.Decimal(8, 4)
  isAnomaly     Boolean   @map("is_anomaly")
  features      Json?     // snapshot of input features
  createdAt     DateTime  @default(now()) @map("created_at")

  region    DimRegion    @relation(fields: [regionId], references: [id])
  commodity DimCommodity @relation(fields: [commodityId], references: [id])

  @@unique([tanggal, regionId, commodityId], name: "uq_anomaly")
  @@index([tanggal, isAnomaly], name: "idx_anomaly_active")
  @@map("analytics_anomaly")
}

// ============================================================
// AUTH & USER TABLES
// ============================================================

enum UserRole {
  ADMIN
  GOVERNMENT_ANALYST
  REGIONAL_OFFICER
  REPORTER
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime? @map("email_verified")
  hashedPassword String?   @map("hashed_password")
  image          String?
  role           UserRole  @default(REPORTER)
  regionId       Int?      @map("region_id")
  phone          String?   @db.VarChar(20)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  region         DimRegion?      @relation(fields: [regionId], references: [id])
  accounts       Account[]
  sessions       Session[]
  priceReports   PriceReport[]
  points         UserPoints?
  badges         UserBadge[]
  notifications  Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// CROWDSOURCED PRICE REPORTS
// ============================================================

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model PriceReport {
  id              String       @id @default(cuid())
  userId          String       @map("user_id")
  commodityId     Int          @map("commodity_id")
  regionId        Int          @map("region_id")
  harga           Decimal      @db.Decimal(12, 2)
  satuan          String       @db.VarChar(20)
  namaPasar       String       @map("nama_pasar") @db.VarChar(200)
  kota            String?      @db.VarChar(100)
  kecamatan       String?      @db.VarChar(100)
  tanggal         DateTime     @db.Date
  catatan         String?      @db.Text
  status          ReportStatus @default(PENDING)
  confidenceScore Decimal?     @map("confidence_score") @db.Decimal(5, 2)
  reviewedBy      String?      @map("reviewed_by")
  reviewedAt      DateTime?    @map("reviewed_at")
  rejectionNote   String?      @map("rejection_note") @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user      User         @relation(fields: [userId], references: [id])
  commodity DimCommodity @relation(fields: [commodityId], references: [id])
  region    DimRegion    @relation(fields: [regionId], references: [id])
  photos    ReportPhoto[]

  @@index([userId, tanggal], name: "idx_report_user")
  @@index([status], name: "idx_report_status")
  @@index([commodityId, regionId, tanggal], name: "idx_report_commodity_region")
  @@map("price_reports")
}

model ReportPhoto {
  id        String   @id @default(cuid())
  reportId  String   @map("report_id")
  url       String   @db.VarChar(500)
  filename  String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  report PriceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_photos")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  message   String   @db.Text
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead], name: "idx_notification_user")
  @@map("notifications")
}

// ============================================================
// GAMIFICATION
// ============================================================

model UserPoints {
  id              String    @id @default(cuid())
  userId          String    @unique @map("user_id")
  totalPoints     Int       @default(0) @map("total_points")
  monthlyPoints   Int       @default(0) @map("monthly_points")
  totalReports    Int       @default(0) @map("total_reports")
  approvedReports Int       @default(0) @map("approved_reports")
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  lastReportDate  DateTime? @map("last_report_date") @db.Date
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_points")
}

model Badge {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String   @db.VarChar(200)
  icon        String   @db.VarChar(50)
  threshold   Int
  category    String   @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}
