# ===========================================
# INFLASI api-gateway (FastAPI) — config
# Consumed by app/config.py (pydantic-settings). Copy to .env for local dev.
# ===========================================

# PostgreSQL — async (SQLAlchemy + asyncpg). NOTE: the var is ANALYTICS_DATABASE_URL,
# not DATABASE_URL. Supabase URLs get SSL + pgbouncer stripping automatically.
# Local dev example:
ANALYTICS_DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/inflasi"

# ETL source base URLs (defaults are sensible; override only if needed)
PIHPS_BASE_URL="https://www.bi.go.id/hargapangan"
BPS_BASE_URL="https://webapi.bps.go.id/v1"
BMKG_BASE_URL="https://data.bmkg.go.id"

# Firebase Admin — verifies ID tokens from the web/Android clients.
# Path to a Firebase service-account JSON (or set GOOGLE_APPLICATION_CREDENTIALS).
FIREBASE_CREDENTIALS_FILE="/secrets/firebase-sa.json"

# External data API keys
BPS_API_KEY=""
EIA_API_KEY=""
